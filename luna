-- Server Hop Button
PlayerTab:CreateButton({
    Name = "Server Hop",
    Callback = function()
        local TeleportService = game:GetService("TeleportService")
        local AllPlayers = game:GetService("Players"):GetPlayers()
        local PlaceId = game.PlaceId
        local RandomPlayer = nil

        local Servers = {}
        -- Ambil semua server
        local success, response = pcall(function()
            return game:GetService("HttpService"):GetAsync("https://games.roblox.com/v1/games/"..PlaceId.."/servers?sortOrder=Asc&limit=100")
        end)
        if success then
            local decoded = game:GetService("HttpService"):JSONDecode(response)
            for _, server in ipairs(decoded.data) do
                if server.playing - server.maxPlayers < 1 then -- server penuh
                    table.insert(Servers, server)
                end
            end
        end

        -- Jika ada server lain, teleport ke server acak
        if #Servers > 0 then
            local server = Servers[math.random(1, #Servers)]
            TeleportService:TeleportToPlaceInstance(PlaceId, server.id)
        else
            -- Jika tidak ada server lain, rejoin otomatis
            game:GetService("TeleportService"):Teleport(PlaceId)
        end
    end,
})
