-- LocalScript → StarterGui
local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

-- FILE DATA
local KeyFile = "rolexhub_key.lua"

-- KEY LIST
local KEYS = {
	"Rolexhub67",
	"premium",
	"dev"
}

local LINK = "https://rekonise.com/key-system-rolex-hub-x-o5y2g"

-- cek key di file
local function isValidKey(input)
	for _,key in pairs(KEYS) do
		if input == key then
			return true
		end
	end
	return false
end

if isfile and isfile(KeyFile) then
	local savedKey = readfile(KeyFile)
	if isValidKey(savedKey) then
		loadstring(game:HttpGet("https://raw.githubusercontent.com/alfaruqdaffa054-ctrl/Rolex-hub-x/refs/heads/main/rolex%20hub"))()
		return
	end
end

